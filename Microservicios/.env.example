# Copy this file to .env before deploying with Docker Compose.

# Public ports
FRONTEND_PORT=3000
GATEWAY_PORT=8000
AUTH_PORT=8081
PROFILE_PORT=8082
MATCHMAKING_PORT=8083
GAME_ENGINE_PORT=8084
STATS_PORT=8085

# Auth configuration
# Use a long random value in production, at least 32 characters for HS256.
JWT_SECRET=change-this-secret-to-a-long-random-production-value
JWT_EXPIRATION=86400000

# JVM tuning for small cloud containers
JAVA_OPTS=-XX:MaxRAMPercentage=75.0
